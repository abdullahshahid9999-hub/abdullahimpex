# Supabase project settings (Project Settings -> API in your Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# SERVICE ROLE key — secret, server-side ONLY. Never give this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Local dev port (Vercel ignores this in production)
PORT=4000
