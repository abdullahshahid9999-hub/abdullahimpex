# Supabase project settings (Project Settings -> API in your Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public ANON key — safe to expose in the browser (used only for login/logout)
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL of your deployed backend (e.g. https://abdullahimpex-backend.vercel.app)
VITE_API_URL=http://localhost:4000
